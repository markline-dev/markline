{
  "openapi": "3.0.0",
  "info": {
    "title": "Example API",
    "version": "1.0.0",
    "description": "A tiny example spec. Replace this with your own openapi.json."
  },
  "servers": [{ "url": "https://api.example.com" }],
  "tags": [{ "name": "widgets", "description": "Manage widgets" }],
  "components": {
    "securitySchemes": {
      "bearer": { "type": "http", "scheme": "bearer", "bearerFormat": "JWT" }
    },
    "schemas": {
      "Widget": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "example": "wgt_123" },
          "name": { "type": "string", "example": "Sprocket" },
          "active": { "type": "boolean", "example": true }
        }
      }
    }
  },
  "security": [{ "bearer": [] }],
  "paths": {
    "/widgets": {
      "get": {
        "operationId": "listWidgets",
        "summary": "List widgets",
        "description": "Return a paginated list of widgets.",
        "tags": ["widgets"],
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "description": "Maximum number of widgets to return.",
            "schema": { "type": "integer", "default": 20 }
          }
        ],
        "responses": {
          "200": {
            "description": "A list of widgets.",
            "content": {
              "application/json": {
                "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Widget" } }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createWidget",
        "summary": "Create a widget",
        "description": "Create a new widget.",
        "tags": ["widgets"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/Widget" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "The created widget.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Widget" }
              }
            }
          }
        }
      }
    }
  }
}
