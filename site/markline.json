{
  "name": "Markline",
  "theme": {
    "colors": { "primary": "#004AAD", "primaryDark": "#4f8ef0" },
    "appearance": "system"
  },
  "topbar": {
    "links": [{ "label": "GitHub ↗", "href": "https://github.com/markline-dev/markline" }],
    "navLinks": [
      { "label": "Why Markline", "href": "/#own" },
      { "label": "Showcase", "href": "/#made" }
    ],
    "homeWidth": "contained",
    "cta": { "label": "Get started", "href": "/quickstart" }
  },
  "navigation": {
    "tabs": [
      {
        "id": "documentation",
        "label": "Documentation",
        "href": "/quickstart",
        "match": ["__default__"],
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              { "href": "/quickstart", "label": "Quickstart" },
              { "href": "/cli", "label": "CLI" }
            ]
          },
          {
            "group": "Authoring",
            "pages": [
              { "href": "/configuration", "label": "Configuration" },
              { "href": "/theming", "label": "Theming" },
              { "href": "/components", "label": "Components" },
              { "href": "/openapi", "label": "API reference" },
              { "href": "/search", "label": "Search" }
            ]
          },
          {
            "group": "Ship",
            "pages": [
              { "href": "/deployment", "label": "Deployment" },
              { "href": "/versions", "label": "Versions & i18n" },
              { "href": "/ai", "label": "Ask AI (BYOK)" },
              { "href": "/feedback", "label": "Feedback" }
            ]
          }
        ]
      },
      {
        "id": "api-reference",
        "label": "API reference",
        "href": "/api-reference",
        "match": ["/api-reference"],
        "openapi": true
      }
    ]
  },
  "api": {
    "baseUrl": "https://api.markline.dev",
    "playground": { "mode": "explorer", "proxy": "auto" }
  },
  "ai": {
    "enabled": true,
    "provider": "openrouter",
    "model": "deepseek/deepseek-v4-flash",
    "mode": "proxy",
    "endpoint": "https://ask.markline.dev",
    "label": "Ask AI",
    "maxTokens": 1024,
    "rateLimit": { "perMinute": 10 }
  },
  "feedback": { "endpoint": "https://feedback.markline.dev" },
  "editUrl": "https://github.com/markline-dev/markline/edit/main/site",
  "seo": {
    "title": "Markline — open-source docs framework",
    "titleTemplate": "%s · Markline",
    "description": "Open-source, self-hostable documentation framework with first-class OpenAPI, search, and an interactive API playground."
  }
}
